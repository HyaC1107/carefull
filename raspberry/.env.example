# ── 서버 연결 (필수) ──────────────────────────────
CAREFULL_API_BASE_URL=https://carefulllion.duckdns.org

# ── 기기 UID (비워두면 MAC 기반 자동 생성) ────────
# CAREFULL_DEVICE_UID=

# ── 화면 설정 ─────────────────────────────────────
CAREFULL_SCREEN_WIDTH=1280
CAREFULL_SCREEN_HEIGHT=600
CAREFULL_FULLSCREEN=1

# ── 카메라 ────────────────────────────────────────
CAREFULL_CAMERA_WIDTH=640
CAREFULL_CAMERA_HEIGHT=480
CAREFULL_CAMERA_WARMUP_SECONDS=2

# ── 복약 스케줄 폴링 주기 (초) ───────────────────
CAREFULL_SCHEDULE_POLL_SECONDS=30

# ── 얼굴 인증 ─────────────────────────────────────
CAREFULL_FACE_MATCH_THRESHOLD=0.8
CAREFULL_AUTH_RETRY_COUNT=5
CAREFULL_AUTH_RETRY_DELAY_SECONDS=1
CAREFULL_API_TIMEOUT=10

# ── 개발/테스트 ───────────────────────────────────
CAREFULL_UI_TEST_MODE=0
CAREFULL_USE_WEBCAM=0
